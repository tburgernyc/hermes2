{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "timeout": 600,
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
