# Hermes 2.0 — .env.example
# Copy to .env.local for dev. NEVER commit real secrets. In production, set these via `fly secrets`.
#
# CRITICAL (CLAUDE.md §4): ANTHROPIC_API_KEY is the APP runtime key. Do NOT `export` it in the shell that
# runs Claude Code, or Claude Code will bill per-token against the API instead of your Max subscription.

# --- Anthropic (app runtime AI engine) ---
ANTHROPIC_API_KEY=

# --- Embeddings (Anthropic does NOT produce embeddings; Voyage powers pgvector matching) ---
VOYAGE_API_KEY=

# --- Database (Neon Postgres, US region) ---
# Requires (run once, as the migration owner): CREATE EXTENSION IF NOT EXISTS vector;
# IMPORTANT: every value below must be a postgresql:// DSN, NOT a Neon Data API REST URL
# (https://…apirest…/rest/v1) — drizzle-kit / node-postgres cannot connect to the REST endpoint.
#
#   DATABASE_URL           runtime, pooled, NON-OWNER role (hermes_app). The app connects with this.
#   DATABASE_URL_UNPOOLED  direct (unpooled) endpoint for migrate/seed/test (DDL + multi-statement).
#   MIGRATION_DATABASE_URL DDL OWNER role, so REVOKE/GRANT on hermes_app actually bind.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
MIGRATION_DATABASE_URL=

# --- Neon control plane (CI ONLY — never ship to Fly): throwaway-branch acceptance tests ---
NEON_API_KEY=
NEON_PROJECT_ID=

# --- TOTP secret encryption (AES-256-GCM; dedicated key — do NOT overload AUTH_SECRET) ---
TOTP_ENCRYPTION_KEY=         # 32-byte key (base64 or hex)

# --- Auth.js v5 ---
AUTH_SECRET=                 # openssl rand -base64 33
AUTH_URL=http://localhost:3000

# --- Signed portal tokens (packages/core/tokens.ts) ---
TOKEN_SIGNING_SECRET=        # >= 32 chars, distinct from AUTH_SECRET

# --- Inngest (durable crons + human-approval gates served at /api/inngest) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Comma-separated org UUIDs the crons operate on (single-tenant simplification — cross-tenant fan-out
# needs a scheduler read-role, deferred). Resolve the seeded org's id and paste it here for local runs.
HERMES_ACTIVE_ORG_IDS=
# EXTERNAL dead-man's-switch (healthchecks.io style). The heartbeat cron pings this https URL every ~10
# min; the external monitor alerts you if pings stop (an app that is down cannot alert on itself).
HEARTBEAT_URL=

# --- App URLs / outbound mail identity ---
# Base URL used to build the signed /quote/[token] and /optout/[token] links in outreach email.
APP_BASE_URL=https://burgergov.com
# From header + CAN-SPAM physical postal address for outreach mail.
OUTREACH_FROM=Burger Consulting <opportunities@burgergov.com>
OUTREACH_POSTAL_ADDRESS=

# --- Resend (email; verify burgergov.com DKIM/SPF) ---
RESEND_API_KEY=

# --- Fly Tigris (S3-compatible object storage) ---
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev
TIGRIS_REGION=auto
TIGRIS_BUCKET=
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=

# --- SAM.gov (request elevated Entity API access for prospect emails) ---
# REQUIRED for live ingestion. The samScan cron / ingestSolicitations FAILS FAST if this is empty —
# it refuses to query api.sam.gov with no key rather than return fake/empty results (CLAUDE.md §1).
SAM_API_KEY=
# Posting-window size (days) for each ingest query. Default 7, clamped 1..365. SAM requires a
# postedFrom/postedTo window (≤ 1 year) or it 400s.
SAM_POSTED_WINDOW_DAYS=7
# Optional SAM `typeOfSetAside` filter (comma-separated codes, e.g. SBA,SBP). Empty = no filter:
# the firm wants to see Total-Small-Business AND unrestricted notices and screen them at triage (§6.7).
SAM_SET_ASIDE=

# --- Live-test mode (CLAUDE.md §2 — BOTH default OFF; production sets neither) ---
# HERMES_TEST_MODE=true makes the proposal "Submit to agency" action a SANDBOXED, AUDITED NO-OP: it never
# transmits a bid (there is no outbound code) and never advances the proposal to SUBMITTED; the attempt is
# logged as BID_SUBMIT_TEST_MODE and a TEST MODE banner shows on the bid surface.
HERMES_TEST_MODE=
# COUNSEL_AUTOFILL=true is effective ONLY when HERMES_TEST_MODE is also true. It auto-resolves the counsel
# gate from the provisional baseline so the workflow can reach READY_TO_SUBMIT without a real counsel review.
# Every OTHER live-submission blocker (SAM registration, CAGE, actual indirect rates) still computes honestly.
COUNSEL_AUTOFILL=

# --- Observability (Sentry; @sentry/nextjs) ---
# The DSN is NOT a secret (it ships in the client bundle by design). Server + edge read SENTRY_DSN; the
# browser SDK reads NEXT_PUBLIC_SENTRY_DSN. Leave BOTH unset to disable Sentry entirely (clean no-op).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (CI ONLY — never ship to Fly). withSentryConfig only generates + uploads maps when
# SENTRY_AUTH_TOKEN is present; absent → no maps, no upload, no network (safe default for dev + public CI).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
